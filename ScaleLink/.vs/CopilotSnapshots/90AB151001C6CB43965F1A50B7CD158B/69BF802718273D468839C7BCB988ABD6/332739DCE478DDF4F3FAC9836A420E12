using ScaleLink.Models;
using ScaleLink.Services;

namespace ScaleLink.Dialogs;

/// <summary>取引先選択ダイアログ</summary>
public partial class SupplierSelectDialog : Form
{
    public SupplierModel? SelectedSupplier { get; private set; }
    public decimal? SelectedWeight { get; private set; }

    private string _sortColumn = nameof(SupplierModel.Code);
    private bool _sortAscending = true;
    private bool _isManualMode;
    private bool _isWeightConfirmed;
    private bool _updatingWeightText;

    public SupplierSelectDialog()
    {
        InitializeComponent();
        LoadSuppliers();
        SetManualMode(false);
        SubscribeWeightEvents();
    }

    private void LoadSuppliers()
    {
        BindSuppliers();
    }

    private void BindSuppliers()
    {
        var suppliers = MasterDataService.Instance.Suppliers.AsEnumerable();

        var nameFilter = txtNameFilter.Text.Trim();
        var carNoFilter = txtCarNoFilter.Text.Trim();

        if (!string.IsNullOrEmpty(nameFilter))
            suppliers = suppliers.Where(x => !string.IsNullOrEmpty(x.Name)
                && x.Name.Contains(nameFilter, StringComparison.CurrentCultureIgnoreCase));

        if (!string.IsNullOrEmpty(carNoFilter))
            suppliers = suppliers.Where(x => !string.IsNullOrEmpty(x.CarNo)
                && x.CarNo.StartsWith(carNoFilter, StringComparison.CurrentCultureIgnoreCase));

        suppliers = _sortColumn switch
        {
            nameof(SupplierModel.Name)  => _sortAscending ? suppliers.OrderBy(x => x.Name)  : suppliers.OrderByDescending(x => x.Name),
            nameof(SupplierModel.CarNo) => _sortAscending ? suppliers.OrderBy(x => x.CarNo) : suppliers.OrderByDescending(x => x.CarNo),
            _                           => _sortAscending ? suppliers.OrderBy(x => x.Code)  : suppliers.OrderByDescending(x => x.Code),
        };

        dgvSuppliers.Rows.Clear();
        foreach (var s in suppliers)
        {
            var index = dgvSuppliers.Rows.Add(s.Code, s.Name, s.CarNo);
            dgvSuppliers.Rows[index].Tag = s;
        }
    }

    private void UpdateFilterControlLayout()
    {
        PositionFilterTextBox(txtNameFilter, colName.Index);
        PositionFilterTextBox(txtCarNoFilter, colCarNo.Index);
    }

    private void PositionFilterTextBox(TextBox textBox, int columnIndex)
    {
        var rect = dgvSuppliers.GetCellDisplayRectangle(columnIndex, -1, true);
        const int margin = 2;

        textBox.Top = (pnlFilters.Height - textBox.Height) / 2;
        textBox.Left = rect.Left + margin;
        textBox.Width = Math.Max(40, rect.Width - margin * 2);
        textBox.Visible = rect.Width > 0;
    }

    private void txtNameFilter_TextChanged(object sender, EventArgs e)
    {
        BindSuppliers();
    }

    private void txtCarNoFilter_TextChanged(object sender, EventArgs e)
    {
        BindSuppliers();
    }

    private void dgvSuppliers_ColumnWidthChanged(object sender, DataGridViewColumnEventArgs e)
    {
        UpdateFilterControlLayout();
    }

    private void dgvSuppliers_Scroll(object sender, ScrollEventArgs e)
    {
        UpdateFilterControlLayout();
    }

    private void SupplierSelectDialog_Shown(object sender, EventArgs e)
    {
        UpdateFilterControlLayout();
    }

    private void SupplierSelectDialog_Resize(object sender, EventArgs e)
    {
        UpdateFilterControlLayout();
    }

    private void btnOk_Click(object sender, EventArgs e) => AcceptSelection();

    private void btnCancel_Click(object sender, EventArgs e)
    {
        DialogResult = DialogResult.Cancel;
        Close();
    }

    private void dgvSuppliers_CellDoubleClick(object sender, DataGridViewCellEventArgs e)
    {
        if (e.RowIndex >= 0)
            AcceptSelection();
    }

    private void dgvSuppliers_ColumnHeaderMouseClick(object sender, DataGridViewCellMouseEventArgs e)
    {
        var colName = dgvSuppliers.Columns[e.ColumnIndex].Name;
        var mapped = colName switch
        {
            "colName"  => nameof(SupplierModel.Name),
            "colCarNo" => nameof(SupplierModel.CarNo),
            _           => nameof(SupplierModel.Code),
        };

        if (_sortColumn == mapped)
            _sortAscending = !_sortAscending;
        else
        {
            _sortColumn = mapped;
            _sortAscending = true;
        }

        BindSuppliers();
        UpdateFilterControlLayout();
    }

    private void btnConfirmWeight_Click(object sender, EventArgs e)
    {
        decimal weight;
        if (_isManualMode)
        {
            if (!decimal.TryParse(txtWeightInput.Text, out weight) || weight <= 0)
            {
                MessageBox.Show("重量は数値で入力してください。", "入力エラー", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
        }
        else
        {
            var status = SerialPortService.Instance.Status;
            if (status == WeightStatus.Error || status == WeightStatus.Disconnected)
            {
                MessageBox.Show("重量が正常に受信できていません。手入力してください。", "受信エラー", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                SetManualMode(true);
                return;
            }

            weight = SerialPortService.Instance.LastWeight;
            if (weight <= 0)
            {
                MessageBox.Show("重量が0です。計量を確認してください。", "確認", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            SetWeightText(weight);
        }

        SelectedWeight = weight;
        _isWeightConfirmed = true;
    }

    private void btnNumPad_Click(object sender, EventArgs e)
    {
        SetManualMode(true);
        using var numPad = new NumPadForm(txtWeightInput.Text);
        if (numPad.ShowDialog(this) == DialogResult.OK)
            txtWeightInput.Text = numPad.InputValue;
    }

    private void txtWeightInput_Click(object sender, EventArgs e)
    {
        SetManualMode(true);
    }

    private void txtWeightInput_KeyPress(object sender, KeyPressEventArgs e)
    {
        if (!char.IsDigit(e.KeyChar) && e.KeyChar != '.' && e.KeyChar != '\b')
            e.Handled = true;
    }

    private void txtWeightInput_TextChanged(object sender, EventArgs e)
    {
        if (_updatingWeightText)
            return;

        _isWeightConfirmed = false;
        SelectedWeight = null;
    }

    private void SubscribeWeightEvents() =>
        SerialPortService.Instance.WeightReceived += OnWeightReceived;

    private void OnWeightReceived(object? sender, WeightReceivedEventArgs e)
    {
        if (InvokeRequired)
        {
            Invoke(() => OnWeightReceived(sender, e));
            return;
        }

        lblCurrentWeight.Text = e.Weight.ToString("#,##0.0");
        (lblWeightStatus.Text, lblWeightStatus.ForeColor) = e.Status switch
        {
            WeightStatus.Stable       => ("● 安定", Color.LimeGreen),
            WeightStatus.Unstable     => ("▲ 計量中", Color.Orange),
            WeightStatus.Error        => ("? 受信エラー", Color.Red),
            WeightStatus.Disconnected => ("─ 未接続", Color.Gray),
            _                         => ("─ 未接続", Color.Gray),
        };
    }

    private void SetManualMode(bool manual)
    {
        _isManualMode = manual;
        txtWeightInput.Enabled = true;
        if (manual)
        {
            lblWeightStatus.Text = "● 手入力モード";
            lblWeightStatus.ForeColor = Color.Cyan;
        }
    }

    private void SetWeightText(decimal weight)
    {
        _updatingWeightText = true;
        txtWeightInput.Text = weight.ToString("#,##0.0");
        _updatingWeightText = false;
    }

    private void AcceptSelection()
    {
        if (!_isWeightConfirmed || SelectedWeight is null || SelectedWeight <= 0)
        {
            MessageBox.Show("重量未確定です。重量確定ボタンで重量を確定してください。", "確認",
                MessageBoxButtons.OK, MessageBoxIcon.Warning);
            return;
        }

        if (dgvSuppliers.CurrentRow?.Tag is SupplierModel supplier)
        {
            SelectedSupplier = supplier;
            DialogResult = DialogResult.OK;
            Close();
        }
        else
        {
            MessageBox.Show("取引先を選択してください。", "確認",
                MessageBoxButtons.OK, MessageBoxIcon.Warning);
        }
    }

    protected override void OnClosed(EventArgs e)
    {
        SerialPortService.Instance.WeightReceived -= OnWeightReceived;
        base.OnClosed(e);
    }
}
