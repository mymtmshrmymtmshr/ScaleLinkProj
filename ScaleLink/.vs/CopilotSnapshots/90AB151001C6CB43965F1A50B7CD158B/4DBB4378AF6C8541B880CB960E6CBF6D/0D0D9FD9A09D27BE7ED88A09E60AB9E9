using ScaleLink.Models;

namespace ScaleLink.Forms;

/// <summary>仕入業者選択パネル</summary>
public partial class SupplierSelectorForm : Form
{
    private readonly MainForm _mainForm;
    private readonly Dictionary<string, WorkspaceForm> _workspaces = [];
    private readonly Dictionary<string, Button> _buttons = [];
    private string _selectedSupplierCode = string.Empty;

    public SupplierSelectorForm(MainForm mainForm)
    {
        _mainForm = mainForm;
        InitializeComponent();
    }

    // ─── 業者追加ボタン ────────────────────────────────────
    private void btnAdd_Click(object sender, EventArgs e)
    {
        using var dlg = new Dialogs.SupplierSelectDialog();
        if (dlg.ShowDialog(this) != DialogResult.OK) return;
        if (dlg.SelectedSupplier is null) return;

        var supplier = dlg.SelectedSupplier;
        var supplierKey = MakeSupplierKey(supplier.Code, supplier.CarNo);
        if (_workspaces.ContainsKey(supplierKey))
        {
            SwitchTo(supplierKey);
            return;
        }

        using var weightDialog = new Dialogs.InitialWeightDialog();
        if (weightDialog.ShowDialog(this) != DialogResult.OK) return;

        AddSupplier(supplier, weightDialog.ConfirmedWeight);
    }

    // ─── 終了ボタン ────────────────────────────────────────
    private void btnExit_Click(object sender, EventArgs e) => _mainForm.RequestClose();

    // ─── 業者ボタン追加 ───────────────────────────────────
    public void AddSupplier(SupplierModel supplier, decimal initialMeasuredWeight)
    {
        var supplierKey = MakeSupplierKey(supplier.Code, supplier.CarNo);

        var ws = _mainForm.AddWorkspace(supplier, initialMeasuredWeight);
        _workspaces[supplierKey] = ws;
        var btn = CreateSupplierButton(supplier);
        _buttons[supplierKey] = btn;
        AttachLongPress(btn, supplierKey);
        pnlList.Controls.Add(btn);
        lblEmpty.Visible = false;
        SwitchTo(supplierKey);
        RefreshListLayout();
    }

    // ─── 業者削除（登録完了後） ───────────────────────────
    public void RemoveSupplier(string supplierCode)
    {
        var supplierKey = ResolveSupplierKey(supplierCode);
        if (supplierKey is null)
            return;

        if (_buttons.TryGetValue(supplierKey, out var btn))
        {
            pnlList.Controls.Remove(btn);
            btn.Dispose();
            _buttons.Remove(supplierKey);
        }
        if (_workspaces.TryGetValue(supplierKey, out var ws))
        {
            ws.Close();
            _workspaces.Remove(supplierKey);
        }

        if (_selectedSupplierCode == supplierKey)
            _selectedSupplierCode = string.Empty;

        if (_workspaces.Count > 0)
            SwitchTo(_workspaces.Keys.First());
        else
            lblEmpty.Visible = true;
    }

    // ─── 業者切替 ──────────────────────────────────────────
    public void SwitchTo(string supplierCode)
    {
        var supplierKey = ResolveSupplierKey(supplierCode);
        if (supplierKey is null) return;
        if (_selectedSupplierCode == supplierKey) return;

        if (_buttons.TryGetValue(_selectedSupplierCode, out var prev))
            UpdateButtonState(prev, SupplierButtonState.Waiting);

        _selectedSupplierCode = supplierKey;

        if (_buttons.TryGetValue(supplierKey, out var cur))
            UpdateButtonState(cur, SupplierButtonState.Selected);
        if (_workspaces.TryGetValue(supplierKey, out var ws))
            ws.Activate();
    }

    // ─── 状態更新 ──────────────────────────────────────────
    public void UpdateSupplierState(string supplierCode, SupplierButtonState state)
    {
        var supplierKey = ResolveSupplierKey(supplierCode);
        if (supplierKey is null || supplierKey == _selectedSupplierCode) return;

        if (_buttons.TryGetValue(supplierKey, out var btn))
            UpdateButtonState(btn, state);
    }

    private static void UpdateButtonState(Button btn, SupplierButtonState state)
    {
        btn.BackColor = state switch
        {
            SupplierButtonState.Weighing => Color.SteelBlue,
            SupplierButtonState.Inputting => Color.RoyalBlue,
            SupplierButtonState.Selected => Color.DodgerBlue,
            _ => Color.Gray,
        };
    }

    // ─── 業者ボタン生成 ───────────────────────────────────
    private Button CreateSupplierButton(SupplierModel supplier)
    {
        var carNo = (supplier.CarNo ?? string.Empty).Trim().Replace("\r", "").Replace("\n", "");
        var buttonSize = new Size(125, 80);

        var btn = new Button
        {
            Text = string.Empty,
            Width = buttonSize.Width,
            Height = buttonSize.Height,
            //Font = CreateBestFitFont(carNo, buttonSize),
            Font = new Font("メイリオ", 8, FontStyle.Bold),
            FlatStyle = FlatStyle.Flat,
            ForeColor = Color.White,
            BackColor = Color.Gray,
            TextAlign = ContentAlignment.MiddleCenter,
            Tag = supplierKey,
            Margin = new Padding(3),
            Padding = new Padding(0),
            AutoEllipsis = true,
            UseMnemonic = false,
            AccessibleName = carNo,
        };
        btn.FlatAppearance.BorderSize = 0;
        btn.Click += (_, _) => SwitchTo(supplierKey);
        btn.Paint += SupplierButton_Paint;
        return btn;
    }

    private static string MakeSupplierKey(string code, string? carNo) =>
        $"{(code ?? string.Empty).Trim()}|{(carNo ?? string.Empty).Trim()}";

    private string? ResolveSupplierKey(string supplierCodeOrKey)
    {
        if (string.IsNullOrWhiteSpace(supplierCodeOrKey))
            return null;

        if (_workspaces.ContainsKey(supplierCodeOrKey))
            return supplierCodeOrKey;

        if (supplierCodeOrKey.Contains('|'))
            return null;

        var code = supplierCodeOrKey.Trim();
        var candidates = _workspaces.Keys
            .Where(k => k.StartsWith(code + "|", StringComparison.Ordinal))
            .ToList();

        if (candidates.Count == 1)
            return candidates[0];

        if (candidates.Count > 1)
            return _selectedSupplierCode != string.Empty && candidates.Contains(_selectedSupplierCode)
                ? _selectedSupplierCode
                : candidates[0];

        return null;
    }

    private static void SupplierButton_Paint(object? sender, PaintEventArgs e)
    {
        if (sender is not Button btn)
            return;

        var carNo = btn.AccessibleName ?? string.Empty;
        var textRect = Rectangle.Inflate(btn.ClientRectangle, -4, -4);

        TextRenderer.DrawText(
            e.Graphics,
            carNo,
            btn.Font,
            textRect,
            btn.ForeColor,
            TextFormatFlags.SingleLine |
            TextFormatFlags.HorizontalCenter |
            TextFormatFlags.VerticalCenter |
            TextFormatFlags.EndEllipsis |
            TextFormatFlags.NoPrefix);
    }

    // ─── 長押し削除 ───────────────────────────────────────
    private void AttachLongPress(Button btn, string supplierCode)
    {
        System.Windows.Forms.Timer? pressTimer = null;
        btn.MouseDown += (_, _) =>
        {
            pressTimer = new System.Windows.Forms.Timer { Interval = 1500 };
            pressTimer.Tick += (_, _) =>
            {
                pressTimer.Stop(); pressTimer.Dispose(); pressTimer = null;
                ConfirmAndRemove(supplierCode);
            };
            pressTimer.Start();
        };
        btn.MouseUp += (_, _) => { pressTimer?.Stop(); pressTimer?.Dispose(); pressTimer = null; };
    }

    private void ConfirmAndRemove(string supplierCode)
    {
        if (!_workspaces.TryGetValue(supplierCode, out var ws)) return;
        var message = ws.HasUnsavedData
            ? "入力中のデータが失われます。削除しますか？"
            : "この業者を削除しますか？";
        if (MessageBox.Show(message, "確認", MessageBoxButtons.YesNo, MessageBoxIcon.Warning) == DialogResult.Yes)
            RemoveSupplier(supplierCode);
    }

    // ─── リストレイアウト更新 ─────────────────────────────
    private void RefreshListLayout()
    {
        int top = 5;
        foreach (Control c in pnlList.Controls)
        {
            if (c is Button btn)
            {
                btn.Left = 5;
                btn.Top = top;
                top += btn.Height + 3;
            }
        }
    }
}

/// <summary>業者ボタンの状態</summary>
public enum SupplierButtonState
{
    Waiting,
    Weighing,
    Inputting,
    Selected,
}
