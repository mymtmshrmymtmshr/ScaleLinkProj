using Microsoft.Data.Sqlite;

namespace ScaleLink.Services;

/// <summary>データベース接続管理サービス（シングルトン）</summary>
public class DatabaseService : IDisposable
{
    private static DatabaseService? _instance;
    private static readonly object _lock = new();
    private SqliteConnection? _connection;

    private static readonly string DbPath =
        Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "scalelink.db");

    private DatabaseService() { }

    public static DatabaseService Instance
    {
        get
        {
            lock (_lock)
            {
                _instance ??= new DatabaseService();
                return _instance;
            }
        }
    }

    /// <summary>DB接続を初期化してテーブルを生成する</summary>
    public void Initialize()
    {
        _connection = new SqliteConnection($"Data Source={DbPath}");
        _connection.Open();
        CreateTables();
    }

    public SqliteConnection Connection =>
        _connection ?? throw new InvalidOperationException("DatabaseService が初期化されていません。");

    /// <summary>テーブルの存在確認・初期生成</summary>
    private void CreateTables()
    {
        var sql = """
            CREATE TABLE IF NOT EXISTS m_supplier (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                code        TEXT    NOT NULL UNIQUE,
                name        TEXT    NOT NULL,
                short_name  TEXT    NOT NULL,
                car_no      TEXT    NOT NULL DEFAULT ''
            );

            CREATE TABLE IF NOT EXISTS m_product (
                id                  INTEGER PRIMARY KEY AUTOINCREMENT,
                code                TEXT    NOT NULL UNIQUE,
                name                TEXT    NOT NULL,
                unit_price          REAL    NOT NULL DEFAULT 0,
                payment_unit_price  REAL    NOT NULL DEFAULT 0,
                is_frequent         INTEGER NOT NULL DEFAULT 0
            );

            CREATE TABLE IF NOT EXISTS m_carrier (
                id   INTEGER PRIMARY KEY AUTOINCREMENT,
                code TEXT    NOT NULL UNIQUE,
                name TEXT    NOT NULL
            );

            CREATE TABLE IF NOT EXISTS m_branch (
                id   INTEGER PRIMARY KEY AUTOINCREMENT,
                code TEXT    NOT NULL UNIQUE,
                name TEXT    NOT NULL
            );

            CREATE TABLE IF NOT EXISTS m_transaction_type (
                id   INTEGER PRIMARY KEY AUTOINCREMENT,
                code TEXT    NOT NULL UNIQUE,
                name TEXT    NOT NULL
            );

            CREATE TABLE IF NOT EXISTS m_payment_type (
                id   INTEGER PRIMARY KEY AUTOINCREMENT,
                code TEXT    NOT NULL UNIQUE,
                name TEXT    NOT NULL
            );

            CREATE TABLE IF NOT EXISTS m_staff (
                id   INTEGER PRIMARY KEY AUTOINCREMENT,
                code TEXT    NOT NULL UNIQUE,
                name TEXT    NOT NULL
            );

            CREATE TABLE IF NOT EXISTS t_measurement_ticket (
                id                  INTEGER PRIMARY KEY AUTOINCREMENT,
                collect_date        TEXT    NOT NULL,
                account_date        TEXT    NOT NULL,
                branch_code         TEXT    NOT NULL,
                transaction_type    TEXT    NOT NULL,
                scale_no            TEXT,
                supplier_code       TEXT    NOT NULL,
                carrier_code        TEXT,
                car_no              TEXT,
                payment_type        TEXT,
                staff_code          TEXT,
                total_quantity      REAL    NOT NULL DEFAULT 0,
                total_count         INTEGER NOT NULL DEFAULT 0,
                total_amount        REAL    NOT NULL DEFAULT 0,
                total_payment       REAL    NOT NULL DEFAULT 0,
                created_at          TEXT    NOT NULL DEFAULT (datetime('now','localtime'))
            );

            CREATE TABLE IF NOT EXISTS t_measurement_detail (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                ticket_id   INTEGER NOT NULL REFERENCES t_measurement_ticket(id),
                no          INTEGER NOT NULL,
                code        TEXT    NOT NULL,
                product_name TEXT   NOT NULL,
                quantity    REAL    NOT NULL DEFAULT 0,
                count       INTEGER NOT NULL DEFAULT 0,
                unit_price  REAL    NOT NULL DEFAULT 0,
                amount      REAL    NOT NULL DEFAULT 0,
                payment     REAL    NOT NULL DEFAULT 0
            );
            """;

        using var cmd = _connection!.CreateCommand();
        cmd.CommandText = sql;
        cmd.ExecuteNonQuery();

        EnsureSupplierSchema();
    }

    private void EnsureSupplierSchema()
    {
        using var cmd = _connection!.CreateCommand();
        cmd.CommandText = "PRAGMA table_info(m_supplier);";

        var hasCarNo = false;
        using var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            var colName = reader.GetString(1);
            if (string.Equals(colName, "car_no", StringComparison.OrdinalIgnoreCase))
            {
                hasCarNo = true;
                break;
            }
        }

        if (!hasCarNo)
        {
            using var alter = _connection.CreateCommand();
            alter.CommandText = "ALTER TABLE m_supplier ADD COLUMN car_no TEXT NOT NULL DEFAULT '';";

            alter.ExecuteNonQuery();
        }
    }

    public void Dispose()
    {
        _connection?.Close();
        _connection?.Dispose();
    }
}
