<Window x:Class="ScaleLink.Forms.ShippingDocumentPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="仕切書プレビュー" 
        Width="900" 
        Height="700"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <Button Content="印刷" 
                DockPanel.Dock="Bottom"
                Width="100" 
                HorizontalAlignment="Right" 
                Margin="0,8,0,0"
                Click="BtnPrint_Click"/>

        <ScrollViewer>
            <Image x:Name="picPreview" Stretch="Uniform"/>
        </ScrollViewer>
    </DockPanel>
</Window>
