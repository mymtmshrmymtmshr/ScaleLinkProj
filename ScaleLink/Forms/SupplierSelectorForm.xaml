<UserControl x:Class="ScaleLink.Forms.SupplierSelectorForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="135"
             Background="#FF2D2D2D">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 追加ボタン（青） -->
        <Button Grid.Row="0"
                x:Name="btnAdd" 
                Content="追加" 
                Height="50" 
                Margin="0"
                Background="#FF0078D7"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="Bold"
                FontFamily="Meiryo UI"
                Click="BtnAdd_Click"/>

        <!-- 取引先リストエリア -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto" 
                      Background="#FF3C3C3C"
                      Margin="0">
            <StackPanel x:Name="pnlList" Margin="5">
                <TextBlock x:Name="lblEmpty" 
                           Text="業者&#x0A;なし" 
                           Foreground="#FF999999"
                           FontSize="14"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,150,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 仮登録呼出しボタン（紫） -->
        <Button Grid.Row="2"
                x:Name="btnTempRecall" 
                Height="50" 
                Margin="0"
                Background="#FF7B68A6"
                Foreground="White"
                BorderThickness="0"
                FontSize="13"
                FontWeight="Bold"
                FontFamily="Meiryo UI"
                Click="BtnTempRecall_Click">
            <TextBlock TextAlignment="Center" LineHeight="16">
                <Run Text="仮登録"/><LineBreak/>
                <Run Text="呼出し"/>
            </TextBlock>
        </Button>

        <!-- 終了ボタン（赤） -->
        <Button Grid.Row="3"
                x:Name="btnExit" 
                Height="50" 
                Margin="0"
                Background="#FFB71C1C"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="Bold"
                FontFamily="Meiryo UI"
                Click="BtnExit_Click">
            <TextBlock Text="終了"/>
        </Button>
    </Grid>
</UserControl>
