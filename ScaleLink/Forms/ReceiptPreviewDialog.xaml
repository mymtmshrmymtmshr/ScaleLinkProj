<Window x:Class="ScaleLink.Forms.ReceiptPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="検収票プレビュー" 
        Width="747" 
        Height="1273"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="印刷"
                    Width="100"
                    Margin="0,0,4,0"
                    Background="#2196F3"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnPrint_Click" FontSize="20"/>
            <Button Content="キャンセル"
                    Width="100"
                    Background="#9E9E9E"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnCancel_Click" Height="35" FontSize="20"/>
        </StackPanel>

        <ScrollViewer>
            <Image x:Name="imgPreview" Source="/Forms/検収票.jpg" Stretch="None"/>
        </ScrollViewer>
    </DockPanel>
</Window>
