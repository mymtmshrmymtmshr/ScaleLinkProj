<Window x:Class="ScaleLink.Dialogs.InitialWeightDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="初期重量入力"
        Width="479"
        Height="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF232631"
        Foreground="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="初期重量を確定してください"
                   HorizontalAlignment="Center"
                   FontSize="36"
                   FontWeight="Bold"
                   Margin="0,8,0,16"/>

        <TextBlock Grid.Row="1"
                   Text="受信重量"
                   HorizontalAlignment="Center"
                   FontSize="34"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       x:Name="lblCurrentWeight"
                       Text="---"
                       Foreground="#FF3CD744"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="72"
                       FontWeight="Bold"
                       Margin="0,0,10,0"/>

            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       Text="kg"
                       VerticalAlignment="Center"
                       FontSize="56"
                       Margin="0,0,8,0"/>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="2"
                       x:Name="lblWeightStatus"
                       Text="● 手入力モード"
                       Foreground="Cyan"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       Margin="0,6,0,0"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="重量手入力"
                       VerticalAlignment="Center"
                       FontSize="26"
                       Margin="0,0,12,0"/>

            <TextBox Grid.Column="1"
                     x:Name="txtManualWeight"
                     Height="42"
                     FontSize="28"
                     VerticalContentAlignment="Center"
                     HorizontalContentAlignment="Right"
                     IsEnabled="False"
                     Background="#FFE8E8E8"
                     Foreground="Black"
                     BorderThickness="0"/>

            <Button Grid.Column="2"
                    Content="電卓"
                    Width="74"
                    Height="42"
                    Margin="10,0,0,0"
                    FontSize="24"
                    Background="#FF4A4C57"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnNumPad_Click"/>
        </Grid>

        <Button Grid.Row="4"
                Content="重量確定"
                Height="74"
                FontSize="52"
                FontWeight="Bold"
                Background="#FF0078D7"
                Foreground="White"
                BorderThickness="0"
                Click="BtnConfirm_Click"/>
    </Grid>
</Window>
