<Window x:Class="ScaleLink.Dialogs.TempRegistrationSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="仮登録検索" 
        Width="900" 
        Height="500"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="集計日" Margin="0,4,4,0"/>
            <DatePicker x:Name="dtpCollectDateFrom" Width="120"/>
            <TextBlock Text="〜" Margin="4,4,4,0"/>
            <DatePicker x:Name="dtpCollectDateTo" Width="120"/>

            <TextBlock Text="計上日" Margin="12,4,4,0"/>
            <DatePicker x:Name="dtpAccountDateFrom" Width="120"/>
            <TextBlock Text="〜" Margin="4,4,4,0"/>
            <DatePicker x:Name="dtpAccountDateTo" Width="120"/>

            <TextBlock Text="車番" Margin="12,4,4,0"/>
            <TextBox x:Name="txtCarNo" Width="80"/>

            <TextBlock Text="取引先" Margin="12,4,4,0"/>
            <TextBox x:Name="txtSupplierCode" Width="80"/>

            <Button Content="検索" Width="70" Margin="12,0,0,0" Click="BtnSearch_Click"/>
            <Button Content="クリア" Width="70" Margin="6,0,0,0" Click="BtnClear_Click"/>
        </WrapPanel>

        <DataGrid x:Name="dgvResults"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  MouseDoubleClick="DgvResults_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="集計日" Binding="{Binding CollectDate, StringFormat='yyyy/MM/dd'}" Width="110"/>
                <DataGridTextColumn Header="計上日" Binding="{Binding AccountDate, StringFormat='yyyy/MM/dd'}" Width="110"/>
                <DataGridTextColumn Header="取引先コード" Binding="{Binding SupplierCode}" Width="110"/>
                <DataGridTextColumn Header="取引先名" Binding="{Binding SupplierName}" Width="200"/>
                <DataGridTextColumn Header="車番" Binding="{Binding CarNo}" Width="110"/>
                <DataGridTextColumn Header="スケールNo" Binding="{Binding ScaleNo}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel DockPanel.Dock="Bottom" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,8,0,0">
            <Button Content="OK" Width="90" Margin="0,0,6,0" Click="BtnOk_Click"/>
            <Button Content="キャンセル" Width="90" Click="BtnCancel_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
