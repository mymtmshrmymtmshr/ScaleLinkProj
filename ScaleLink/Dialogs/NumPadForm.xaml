<Window x:Class="ScaleLink.Dialogs.NumPadForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重量入力"
        Width="300"
        Height="530"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF3E5A66">
    <Window.Resources>
        <Style x:Key="BaseKeyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF4A4C59"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="0" Background="#FF3A3D49">
        <TextBox x:Name="txtDisplay"
                 DockPanel.Dock="Top"
                 Height="82"
                 FontSize="24"
                 IsReadOnly="True"
                 HorizontalContentAlignment="Right"
                 Background="#FFDADADA"
                 Foreground="Black"
                 BorderThickness="0"/>

        <Button Content="OK"
                DockPanel.Dock="Bottom"
                Height="84"
                Margin="4,4,4,4"
                Style="{StaticResource BaseKeyButtonStyle}"
                Background="#FF0E7EC8"
                Click="BtnOk_Click"/>

        <UniformGrid Rows="4" Columns="3" Margin="4,4,4,0" Background="#FF3A3D49">
            <Button Content="7" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="8" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="9" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="4" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="5" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="6" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="1" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="2" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="3" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="C" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Background="#FFB51B1F" Click="NumKey_Click"/>
            <Button Content="0" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Click="NumKey_Click"/>
            <Button Content="◀" Margin="2" Style="{StaticResource BaseKeyButtonStyle}" Background="#FF6B5900" Click="NumKey_Click"/>
        </UniformGrid>
    </DockPanel>
</Window>
