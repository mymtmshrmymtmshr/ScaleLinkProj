    public TempRegistrationSearchResult? SelectedRegistration { get; private set; }

    public TempRegistrationSearchDialog()
    {
        InitializeComponent();
        InitializeSearchConditions();
    }

    private void InitializeSearchConditions()
    {
        dtpCollectDateFrom.Value = DateTime.Today.AddDays(-7);
        dtpCollectDateTo.Value = DateTime.Today;
        dtpAccountDateFrom.Value = DateTime.Today.AddDays(-7);
        dtpAccountDateTo.Value = DateTime.Today;
    }

    private void btnSearch_Click(object sender, EventArgs e)
    {
        SearchTempRegistrations();
    }

    private void btnClear_Click(object sender, EventArgs e)
    {
        txtCarNo.Clear();
        txtSupplierCode.Clear();
        InitializeSearchConditions();
        dgvResults.Rows.Clear();
    }

    private void SearchTempRegistrations()
    {
        dgvResults.Rows.Clear();

        try
        {
            // ダミーデータ生成（開発・テスト用）
            var suppliers = Services.MasterDataService.Instance.Suppliers;
            if (suppliers.Count == 0)
            {
                MessageBox.Show("取引先マスタが登録されていません。", "エラー",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var random = new Random();
            var baseDate = DateTime.Today;

            // 10件のダミーデータを生成
            for (int i = 0; i < 10; i++)
            {
                // ランダムに取引先を選択
                var supplier = suppliers[random.Next(suppliers.Count)];

                // 日付を過去にランダムにずらす
                var daysAgo = random.Next(0, 30);
                var collectDate = baseDate.AddDays(-daysAgo);
                var accountDate = collectDate.AddDays(random.Next(0, 3));

                // スケール№を6桁のランダム数値で生成
                var scaleNo = random.Next(100000, 999999).ToString();

                // 車番（取引先の車番またはランダム）
                var carNo = string.IsNullOrWhiteSpace(supplier.CarNo) 
                    ? $"{random.Next(1000, 9999)}" 
                    : supplier.CarNo;

                // ダミーのticket_id（実際はデータベースから取得）
                var ticketId = 1000 + i;

                var index = dgvResults.Rows.Add(
                    collectDate.ToString("yyyy/MM/dd"),
                    accountDate.ToString("yyyy/MM/dd"),
                    supplier.Code,
                    carNo,
                    scaleNo
                );

                dgvResults.Rows[index].Tag = new TempRegistrationSearchResult
                {
                    TicketId = ticketId,
                    CollectDate = collectDate,
                    AccountDate = accountDate,
                    SupplierCode = supplier.Code,
                    CarNo = carNo,
                    ScaleNo = scaleNo
                };
            }

            if (dgvResults.Rows.Count == 0)
            {
                MessageBox.Show("検索条件に該当するデータがありません。", "検索結果",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
        }
        catch (Exception ex)
        {
            MessageBox.Show($"検索エラー:\n{ex.Message}", "エラー",
                MessageBoxButtons.OK, MessageBoxIcon.Error);
        }

