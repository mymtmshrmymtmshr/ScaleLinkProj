using ScaleLink.Models;

namespace ScaleLink.Forms;

/// <summary>業者ごとの作業エリアコンテナ</summary>
public partial class WorkspaceForm : Form
{
    private readonly SupplierSelectorForm _selector;
    private readonly decimal _initialMeasuredWeight;
    public SupplierModel Supplier { get; }
    private WeightInputForm _weightInput = null!;
    private MeasurementTicketForm _ticketForm = null!;
    public bool HasUnsavedData => _ticketForm?.HasUnsavedData ?? false;

    public WorkspaceForm(SupplierModel supplier, SupplierSelectorForm selector, decimal initialMeasuredWeight)
    {
        Supplier = supplier;
        _selector = selector;
        _initialMeasuredWeight = initialMeasuredWeight;
        InitializeComponent();
        InitializeChildForms();
    }

    private void InitializeChildForms()
    {
        _ticketForm = new MeasurementTicketForm(Supplier, _selector, _initialMeasuredWeight);
        _ticketForm.TopLevel        = false;
        _ticketForm.FormBorderStyle = FormBorderStyle.None;
        _ticketForm.Dock            = DockStyle.Fill;

        _weightInput = new WeightInputForm(_ticketForm, _selector, Supplier.Code);
        _weightInput.TopLevel        = false;
        _weightInput.FormBorderStyle = FormBorderStyle.None;
        _weightInput.Dock            = DockStyle.Left;
        _weightInput.Width           = 345;

        Controls.Add(_ticketForm);
        Controls.Add(_weightInput);
        _ticketForm.Show();
        _weightInput.Show();
    }

    protected override void OnClosed(EventArgs e)
    {
        base.OnClosed(e);
        _weightInput?.Close();
        _ticketForm?.Close();
    }
}
