using ScaleLink.Services;

namespace ScaleLink.Forms;

/// <summary>MDI親フォーム</summary>
public class MainForm : Form
{
    private SupplierSelectorForm _supplierSelector = null!;
    private Panel _workspaceArea = null!;

    public MainForm()
    {
        InitializeComponent();
        InitializeServices();
        InitializeChildForms();
    }

    // ─── UI構築 ────────────────────────────────────────────
    private void InitializeComponent()
    {
        SuspendLayout();

        Text            = "ScaleLink - 計量票入力";
        IsMdiContainer  = true;
        WindowState     = FormWindowState.Maximized;
        FormBorderStyle = FormBorderStyle.None;
        KeyPreview      = true;
        BackColor       = Color.FromArgb(30, 30, 30);

        // MDIクライアント領域の色を統一
        foreach (Control c in Controls)
            if (c is MdiClient mdi)
                mdi.BackColor = Color.FromArgb(30, 30, 30);

        ResumeLayout(false);
    }

    // ─── サービス初期化 ────────────────────────────────────
    private void InitializeServices()
    {
        try
        {
            DatabaseService.Instance.Initialize();
            MasterDataService.Instance.Load();

            // RS-232C は後で設定画面から起動できるよう、ここでは接続しない
            // SerialPortService.Instance.Start("COM1");
        }
        catch (Exception ex)
        {
            MessageBox.Show($"初期化エラー:\n{ex.Message}", "エラー",
                MessageBoxButtons.OK, MessageBoxIcon.Error);
        }
    }

    // ─── 子フォーム初期化 ──────────────────────────────────
    private void InitializeChildForms()
    {
        // 業者選択パネルを左端に配置
        _supplierSelector = new SupplierSelectorForm(this);
        _supplierSelector.TopLevel = false;
        _supplierSelector.FormBorderStyle = FormBorderStyle.None;
        _supplierSelector.Dock = DockStyle.Left;
        _supplierSelector.Width = 90;

        Controls.Add(_supplierSelector);
        _supplierSelector.BringToFront();
        _supplierSelector.Show();
    }

    // ─── 業者ワークスペースの追加・削除 ───────────────────
    /// <summary>指定業者のWorkspaceFormを生成してMDIクライアントに追加する</summary>
    public WorkspaceForm AddWorkspace(Models.SupplierModel supplier)
    {
        var ws = new WorkspaceForm(supplier, _supplierSelector);
        ws.MdiParent = this;
        ws.FormBorderStyle = FormBorderStyle.None;
        ws.WindowState = FormWindowState.Maximized;
        ws.Show();
        return ws;
    }

    // ─── キーボードショートカット ─────────────────────────
    protected override bool ProcessCmdKey(ref Message msg, Keys keyData)
    {
        if (keyData == (Keys.Alt | Keys.F4))
        {
            RequestClose();
            return true;
        }
        return base.ProcessCmdKey(ref msg, keyData);
    }

    // ─── 終了処理 ──────────────────────────────────────────
    public void RequestClose()
    {
        if (HasUnsavedData())
        {
            var result = MessageBox.Show(
                "入力中のデータがあります。終了しますか？",
                "確認", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);
            if (result != DialogResult.Yes) return;
        }
        CleanupAndClose();
    }

    private bool HasUnsavedData()
    {
        foreach (Form child in MdiChildren)
            if (child is WorkspaceForm ws && ws.HasUnsavedData)
                return true;
        return false;
    }

    private void CleanupAndClose()
    {
        foreach (Form child in MdiChildren)
            child.Close();

        SerialPortService.Instance.Stop();
        DatabaseService.Instance.Dispose();
        Application.Exit();
    }

    protected override void OnFormClosing(FormClosingEventArgs e)
    {
        base.OnFormClosing(e);
        SerialPortService.Instance.Stop();
        DatabaseService.Instance.Dispose();
    }
}
