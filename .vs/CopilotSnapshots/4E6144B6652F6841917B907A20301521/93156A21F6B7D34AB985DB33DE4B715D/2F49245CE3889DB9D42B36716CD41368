using ScaleLink.Models;
using ScaleLink.Services;

namespace ScaleLink.Dialogs;

/// <summary>取引先選択ダイアログ</summary>
public partial class SupplierSelectDialog : Form
{
    public SupplierModel? SelectedSupplier { get; private set; }

    public SupplierSelectDialog()
    {
        InitializeComponent();
        LoadSuppliers();
    }

    private void LoadSuppliers()
    {
        foreach (var s in MasterDataService.Instance.Suppliers)
            lstSuppliers.Items.Add(new SupplierListItem(s));
    }

    private void btnOk_Click(object sender, EventArgs e) => AcceptSelection();
    private void btnCancel_Click(object sender, EventArgs e)
    {
        DialogResult = DialogResult.Cancel;
        Close();
    }
    private void lstSuppliers_DoubleClick(object sender, EventArgs e) => AcceptSelection();

    private void AcceptSelection()
    {
        if (lstSuppliers.SelectedItem is SupplierListItem item)
        {
            SelectedSupplier = item.Supplier;
            DialogResult = DialogResult.OK;
            Close();
        }
        else
        {
            MessageBox.Show("取引先を選択してください。", "確認",
                MessageBoxButtons.OK, MessageBoxIcon.Warning);
        }
    }

    private record SupplierListItem(SupplierModel Supplier)
    {
        public override string ToString() => $"{Supplier.Code}  {Supplier.Name}";
    }
}
